# ABI-Bench v0.1 — Provider Configuration
#
# Copy this file to bench/.env and fill in your API keys.
# The benchmark harness loads this file automatically.
#
# Supported providers: anthropic, openai, deepseek, qwen, glm, kimi, mimo,
#                      google, openai-compatible
#
# Choose ONE of the following configurations:

# ── Option 1: Anthropic (Claude) ──────────────────────────────────────
# ABI_BENCH_PROVIDER=anthropic
# ABI_BENCH_API_KEY=sk-ant-...
# ABI_BENCH_MODEL=anthropic/claude-sonnet-4-5

# ── Option 2: OpenAI ──────────────────────────────────────────────────
# ABI_BENCH_PROVIDER=openai
# ABI_BENCH_API_KEY=sk-...
# ABI_BENCH_MODEL=openai/gpt-4o

# ── Option 3: DeepSeek (OpenAI-compatible) ────────────────────────────
# ABI_BENCH_PROVIDER=deepseek
# ABI_BENCH_API_KEY=sk-...
# ABI_BENCH_API_BASE=https://api.deepseek.com
# ABI_BENCH_MODEL=deepseek-v4-pro

# ── Option 4: Qwen / Alibaba DashScope (OpenAI-compatible) ────────────
# ABI_BENCH_PROVIDER=qwen
# ABI_BENCH_API_KEY=sk-...
# ABI_BENCH_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# ABI_BENCH_MODEL=qwen3-235b-a22b

# ── Option 5: GLM / Zhipu BigModel (OpenAI-compatible) ───────────────
# ABI_BENCH_PROVIDER=glm
# ABI_BENCH_API_KEY=...
# ABI_BENCH_API_BASE=https://open.bigmodel.cn/api/paas/v4
# ABI_BENCH_MODEL=GLM-4-Plus

# ── Option 6: Kimi / Moonshot (OpenAI-compatible) ────────────────────
# ABI_BENCH_PROVIDER=kimi
# ABI_BENCH_API_KEY=sk-...
# ABI_BENCH_API_BASE=https://api.moonshot.cn/v1
# ABI_BENCH_MODEL=kimi-k2

# ── Option 7: MiMo (OpenAI-compatible) ────────────────────────────────
# ABI_BENCH_PROVIDER=mimo
# ABI_BENCH_API_KEY=...
# ABI_BENCH_API_BASE=<your-mimo-endpoint>
# ABI_BENCH_MODEL=mimo-pro

# ── Option 8: Google Gemini ───────────────────────────────────────────
# ABI_BENCH_PROVIDER=google
# ABI_BENCH_API_KEY=...
# ABI_BENCH_MODEL=gemini-2.5-pro

# ── Option 9: Custom OpenAI-compatible endpoint ───────────────────────
# ABI_BENCH_PROVIDER=openai-compatible
# ABI_BENCH_API_KEY=your-key
# ABI_BENCH_API_BASE=https://your-endpoint.com/v1

# ── Reasoning model support (optional) ──────────────────────────────────
# Enable extended thinking / reasoning for compatible models.
# When true, the harness passes thinking parameters to the API and
# captures reasoning traces in a separate reasoning_trace.jsonl file.
# Auto-detected from model name when unset, but this provides an
# explicit override.
# ABI_BENCH_REASONING=true

# Anthropic / Google thinking budget in tokens (1024–128000).
# When set, also passed to Qwen (DashScope) as thinking budget.
# ABI_BENCH_THINKING_BUDGET=16000

# Reasoning effort for OpenAI / Qwen / GLM / Kimi / MiMo (low, medium, high).
# When unset, the provider's default is used.
# ABI_BENCH_REASONING_EFFORT=medium
