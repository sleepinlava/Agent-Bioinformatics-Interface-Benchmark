#!/usr/bin/env bash
# Wrapper to run opencode CLI
# Prefer globally-installed opencode; fall back to vendored copy

# Try global opencode binary first (not this wrapper itself)
if command -v opencode >/dev/null 2>&1; then
    GLOBAL="$(command -v opencode)"
    # Make sure we're not recursing into ourselves
    if [ "$GLOBAL" != "$0" ]; then
        exec "$GLOBAL" "$@"
    fi
fi

# Fall back to vendored opencode repo
OPENEROOT="$(cd "$(dirname "$0")/../../agent/opencode" 2>/dev/null && pwd)"
if [ -d "$OPENEROOT" ]; then
    export PATH="$HOME/.bun/bin:$PATH"
    exec bun run --cwd "$OPENEROOT" packages/cli/src/index.ts "$@"
fi

echo "ERROR: opencode not found on PATH and no vendored copy at agent/opencode" >&2
echo "Install with: npm install -g opencode  or  bun install -g opencode" >&2
exit 1
