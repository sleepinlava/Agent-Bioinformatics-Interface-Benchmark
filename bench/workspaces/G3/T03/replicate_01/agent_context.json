{
  "benchmark": "ABI-Bench",
  "version": "0.1",
  "group_id": "G3",
  "task_id": "T03",
  "task_prompt": "Run a dry-run for metagenomic plasmid analysis.\nIt must write execution plan, provenance, commands, standard tables,\nand report artifacts. Do not execute real bioinformatics tools.\n",
  "allowed_actions": {
    "read_files": true,
    "write_files": true,
    "run_shell": true,
    "real_tool_execution": false,
    "network": false
  },
  "agent_profile": {
    "allowed_tools": [
      "abi_list_types",
      "abi_plan",
      "abi_dry_run",
      "abi_inspect",
      "abi_report",
      "abi_export_nextflow",
      "read_file",
      "list_files"
    ],
    "forbidden_tools": [],
    "restricted_tools": {
      "abi_run": {
        "requires_confirm_execution": true,
        "default_available": false
      }
    },
    "required_behavior": [
      "use_lifecycle_operations",
      "use_provenance_for_diagnosis",
      "respect_permission_gate",
      "do_not_upload_large_bio_payloads"
    ],
    "rule": ""
  },
  "workspace_files": [
    {
      "path": "config.yaml",
      "size": 1883
    },
    {
      "path": "sample_sheet.tsv",
      "size": 624
    },
    {
      "path": "data/.gitkeep",
      "size": 0
    }
  ],
  "expected_artifacts": [
    "execution_plan.json",
    "provenance/commands.tsv",
    "provenance/resolved_inputs.tsv",
    "provenance/tool_versions.tsv",
    "provenance/resources.json",
    "provenance/run_summary.json",
    "provenance/progress.jsonl",
    "tables",
    "report/report.md",
    "report/report.html"
  ],
  "max_agent_steps": 50,
  "timeout_minutes": 20
}